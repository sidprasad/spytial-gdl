{
  "name": "spytial-gdl",
  "version": "0.0.7",
  "description": "A small graph description language (GDL) with inline spatial @annotations, rendered as live Spytial constraint diagrams in Markdown or anywhere.",
  "keywords": [
    "graph",
    "gdl",
    "diagram",
    "mermaid",
    "spytial",
    "constraint-layout",
    "visualization",
    "markdown"
  ],
  "author": "Siddhartha Prasad (https://github.com/sidprasad)",
  "license": "MIT",
  "homepage": "https://github.com/sidprasad/spytial-gdl#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sidprasad/spytial-gdl.git"
  },
  "bugs": {
    "url": "https://github.com/sidprasad/spytial-gdl/issues"
  },
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "index.html",
    "src",
    "playground",
    "examples",
    "README.md",
    "GUIDE.md"
  ],
  "scripts": {
    "serve": "node scripts/preview-server.mjs",
    "test": "node test/roundtrip.test.mjs && node test/parse.test.mjs && node test/annotations.test.mjs && node test/sgq-integration.test.mjs",
    "test:roundtrip": "node test/roundtrip.test.mjs",
    "test:parse": "node test/parse.test.mjs",
    "test:annotations": "node test/annotations.test.mjs",
    "test:integration": "node test/sgq-integration.test.mjs"
  },
  "peerDependencies": {
    "spytial-core": "^2.10.1"
  }
}
